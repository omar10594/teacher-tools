# Public app URL (used if you add callbacks/links later)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required: n8n webhook URL that receives startDate and weekNumber
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/your-weekly-plan

# Required for auth token signing
AUTH_SECRET=replace-with-a-long-random-secret

# Allowed emails for private access
AUTH_ALLOWED_EMAILS=teacher@example.com,assistant@example.com

# Required to send magic links with Resend
RESEND_API_KEY=re_xxxxxxxxxxxxx
AUTH_FROM_EMAIL=Teacher Tools <no-reply@example.com>
